{
  "manifest_version": 3,
  "name": "Growth Garden",
  "version": "1.0",
  "description": "Grow your garden with sustainable AI practices.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:3000/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"]
    }
  ]
}
